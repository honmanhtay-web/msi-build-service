# Path: msi-build-service/.env.example
# Purpose: Mẫu biến môi trường — copy thành .env và điền giá trị thực
# Last Updated: 2026-04-03
# QUAN TRỌNG: File .env KHÔNG được commit vào git

# ─── FIREBASE ───────────────────────────────────────────────────────────────
# URL Firebase Realtime DB (lấy từ Firebase Console > Project Settings)
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com

# Service Account Key dưới dạng JSON string (lấy từ Firebase Console > Service Accounts)
# Encode toàn bộ JSON thành 1 dòng string
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"..."}

# Path gốc trên Firebase (default: build-queue)
FIREBASE_BUILD_QUEUE_PATH=build-queue

# ─── SERVICE IDENTITY ────────────────────────────────────────────────────────
# ID định danh máy này — dùng để claim job, tránh race condition
# Nên set theo hostname thật, ví dụ: build-machine-01, azure-vm-02
SERVICE_MACHINE_ID=build-machine-01

# ─── ADVANCED INSTALLER ──────────────────────────────────────────────────────
# Path đầy đủ tới advinst.exe
# Nếu không set, service sẽ tự dò theo thứ tự ưu tiên (xem ConfigResolver.js)
ADVINST_EXE_PATH=C:\Program Files (x86)\Caphyon\Advanced Installer 21.3\bin\x86\advinst.exe

# ─── GIT ────────────────────────────────────────────────────────────────────
# Personal Access Token để clone private repos
GIT_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Username dùng để authenticate git (thường là tên GitHub account hoặc org bot)
GIT_USERNAME=your-github-username

# ─── BUILD ───────────────────────────────────────────────────────────────────
# Số job build chạy đồng thời tối đa trên 1 instance service
BUILD_MAX_CONCURRENT=2

# Timeout (giây) cho mỗi lần chạy advinst.exe
BUILD_TIMEOUT_SECONDS=300

# ─── UPLOAD: AWS S3 (hoặc S3-compatible) ────────────────────────────────────
UPLOAD_S3_ENABLED=true
UPLOAD_S3_BUCKET=your-msi-bucket
UPLOAD_S3_REGION=ap-southeast-1
UPLOAD_S3_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
UPLOAD_S3_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# Prefix thư mục trong bucket (tùy chọn)
UPLOAD_S3_KEY_PREFIX=releases/

# ─── UPLOAD: MICROSOFT ONEDRIVE ──────────────────────────────────────────────
UPLOAD_ONEDRIVE_ENABLED=true
# App đăng ký trong Azure AD (Application ID)
UPLOAD_ONEDRIVE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
UPLOAD_ONEDRIVE_CLIENT_SECRET=your-client-secret
UPLOAD_ONEDRIVE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Đường dẫn thư mục trên OneDrive (bắt đầu bằng /)
UPLOAD_ONEDRIVE_FOLDER_PATH=/MSI-Releases

# ─── UPLOAD: GOOGLE DRIVE ────────────────────────────────────────────────────
UPLOAD_GDRIVE_ENABLED=true
# Service Account Key dưới dạng JSON string (tương tự Firebase)
UPLOAD_GDRIVE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}
# ID thư mục trên Google Drive (lấy từ URL khi mở thư mục)
UPLOAD_GDRIVE_FOLDER_ID=1aBcDeFgHiJkLmNoPqRsTuVwXyZ

# ─── UPLOAD: SYNOLOGY NAS ────────────────────────────────────────────────────
UPLOAD_NAS_ENABLED=true
# URL cơ sở của Synology DSM (có thể là IP nội bộ hoặc domain)
UPLOAD_NAS_BASE_URL=http://192.168.1.100:5000
UPLOAD_NAS_USERNAME=build-service
UPLOAD_NAS_PASSWORD=your-nas-password
# Đường dẫn thư mục share trên NAS
UPLOAD_NAS_SHARE_FOLDER=/MSI-Releases

# ─── CLEANUP TTL ─────────────────────────────────────────────────────────────
# Số ngày giữ record "done"/"skipped" trước khi xóa
CLEANUP_DONE_DAYS=7

# Số ngày giữ record "failed" trước khi xóa
CLEANUP_FAILED_DAYS=7

# Số ngày giữ record "pending" stale trước khi xóa
CLEANUP_PENDING_DAYS=30

# Số giờ trước khi reset job "claimed"/"building" về "pending" (crash recovery)
CLEANUP_STUCK_HOURS=2

# Tần suất chạy cleanup (phút)
CLEANUP_INTERVAL_MINUTES=60

# ─── LOGGING ─────────────────────────────────────────────────────────────────
# Level log: debug | info | warn | error
LOG_LEVEL=info

# Thư mục lưu log file (relative từ project root)
LOG_DIR=logs
